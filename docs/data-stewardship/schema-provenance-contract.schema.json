{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ribodb.local/schema/entity-envelope.v1.json",
  "title": "Unified Entity Envelope",
  "type": "object",
  "required": [
    "entity_id",
    "entity_type",
    "display_name",
    "summary",
    "organism",
    "status",
    "evidence",
    "provenance",
    "updated_at"
  ],
  "properties": {
    "entity_id": { "type": "string", "minLength": 1 },
    "entity_type": {
      "type": "string",
      "enum": ["riboswitch", "aptamer", "rRNA_centre"]
    },
    "display_name": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "organism": {
      "type": "object",
      "required": ["taxon_id", "scientific_name"],
      "properties": {
        "taxon_id": { "type": "string", "minLength": 1 },
        "scientific_name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "draft"]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "method",
          "score",
          "direction",
          "publication",
          "replicates",
          "quality_flag"
        ],
        "properties": {
          "evidence_id": { "type": "string", "minLength": 1 },
          "method": { "type": "string", "minLength": 1 },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "direction": {
            "type": "string",
            "enum": ["supporting", "contradicting", "neutral"]
          },
          "publication": {
            "type": "object",
            "required": ["pmid", "title"],
            "properties": {
              "pmid": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "replicates": { "type": "integer", "minimum": 1 },
          "quality_flag": {
            "type": "string",
            "enum": ["pass", "warn", "fail"]
          }
        },
        "additionalProperties": false
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "source_dataset_id",
        "source_url",
        "license",
        "collection_date",
        "ingest_timestamp",
        "preprocessing_steps",
        "version",
        "curation_owner",
        "confidence_status"
      ],
      "properties": {
        "source_dataset_id": { "type": "string", "minLength": 1 },
        "source_url": { "type": "string", "format": "uri" },
        "license": {
          "type": "string",
          "enum": ["CC-BY-4.0", "CC0-1.0", "MIT", "ODC-By"]
        },
        "collection_date": { "type": "string", "format": "date" },
        "ingest_timestamp": { "type": "string", "format": "date-time" },
        "preprocessing_steps": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "version": { "type": "string", "minLength": 1 },
        "curation_owner": { "type": "string", "const": "research_data_steward" },
        "confidence_status": {
          "type": "string",
          "enum": ["verified", "provisional", "retracted"]
        }
      },
      "additionalProperties": false
    },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
